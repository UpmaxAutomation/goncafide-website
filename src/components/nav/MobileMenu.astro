---
const navLinks = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/nvc-nedir', label: 'NVC Nedir?' },
  { href: '/hakkimda', label: 'Hakkımda' },
  { href: '/programlar', label: 'Sunduklarım' },
  { href: '/etkinlikler', label: 'Etkinlikler' },
  { href: '/blog', label: 'Blog' },
  { href: '/sss', label: 'SSS' },
  { href: '/iletisim', label: 'İletişim' },
];

const pathname = Astro.url.pathname;
---

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Navigasyon menüsü"
  aria-modal="true"
  aria-hidden="true"
  class="fixed inset-0 z-50 flex flex-col bg-[var(--color-canvas)] opacity-0 pointer-events-none transition-all duration-300 ease-in-out"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)]">
    <a href="/" class="leading-none" aria-label="Gonca Fide — birbirine bağlar">
      <span class="block font-display text-xl font-light tracking-tight text-[var(--color-ink)]">Gonca Fide</span>
      <span class="block font-body text-[10px] font-medium tracking-[0.2em] uppercase text-[var(--color-terra-500)] mt-1">birbirine bağlar</span>
    </a>
    <button
      id="mobile-menu-close"
      aria-label="Menüyü kapat"
      class="flex items-center justify-center w-12 h-12 rounded-lg text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] hover:bg-[var(--color-surface)] transition-colors"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex-1 flex flex-col justify-center px-8 py-6 gap-1">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'flex items-center py-4 px-2 font-display text-3xl font-light tracking-tight transition-colors border-b border-[var(--color-border)]',
          pathname === link.href
            ? 'text-[var(--color-sage-800)]'
            : 'text-[var(--color-ink)] hover:text-[var(--color-sage-600)]'
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Footer CTA -->
  <div class="px-8 py-8">
    <a
      href="/iletisim"
      class="flex items-center justify-center w-full py-4 px-6 rounded-xl bg-[var(--color-terra-500)] text-white font-body font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] transition-colors min-h-[48px]"
    >
      İletişime Geç
    </a>
    <a
      href="https://wa.me/905337167940"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 flex items-center justify-center gap-2 w-full py-3.5 px-6 rounded-xl border border-[var(--color-sage-300)] text-[var(--color-sage-700)] font-body font-semibold text-sm hover:bg-[var(--color-sage-50)] transition-colors min-h-[48px]"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 18.15c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 4.54 0 8.23 3.69 8.23 8.23 0 4.54-3.69 8.24-8.23 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
      WhatsApp ile yazın
    </a>
    <div class="mt-4 flex items-center gap-4 justify-center flex-wrap">
      <a href="tel:+905337167940" class="text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] text-sm transition-colors">+90 533 716 79 40</a>
      <span class="text-[var(--color-ink-faint)]">·</span>
      <a
        href="https://instagram.com/goncolog"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] text-sm transition-colors"
        aria-label="Instagram @goncolog"
      >
        @goncolog
      </a>
      <span class="text-[var(--color-ink-faint)]">·</span>
      <a
        href="mailto:info@goncafide.com"
        class="text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] text-sm transition-colors"
      >
        info@goncafide.com
      </a>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById('mobile-menu');
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');

  function openMenu() {
    if (!menu) return;
    menu.setAttribute('aria-hidden', 'false');
    menu.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeMenu() {
    if (!menu) return;
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
    openBtn?.focus();
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.getAttribute('aria-hidden') === 'false') {
      closeMenu();
    }
  });

  // Close on nav link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
