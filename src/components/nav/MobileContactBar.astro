---
// Mobile-only sticky contact bar. Calm utility (WhatsApp + contact) — not a popup.
// Hidden on the contact page itself to avoid redundancy.
const path = Astro.url.pathname;
const hide = path.startsWith('/iletisim');
---
{!hide && (
  <Fragment>
    <div class="h-[4.25rem] lg:hidden" aria-hidden="true"></div>
    <div
      class="lg:hidden fixed bottom-0 inset-x-0 z-40 border-t border-[var(--color-border)] bg-[var(--color-canvas)]/95 backdrop-blur-sm"
      style="padding-bottom: env(safe-area-inset-bottom);"
    >
      <div class="grid grid-cols-2 gap-2.5 p-2.5">
        <a
          href="mailto:info@goncafide.com"
          class="flex items-center justify-center gap-2 py-3 rounded-xl border border-[var(--color-plum-300)] text-[var(--color-plum-700)] font-semibold text-sm min-h-[48px] active:scale-[0.98] transition-transform"
          aria-label="E-posta gönderin"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7l8.4 5.6a1 1 0 0 0 1.2 0L21 7M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          E-posta
        </a>
        <a
          href="/iletisim"
          class="flex items-center justify-center gap-2 py-3 rounded-xl bg-[var(--color-orchid-500)] text-white font-semibold text-sm min-h-[48px] active:scale-[0.98] transition-transform"
        >
          İletişime Geç
        </a>
      </div>
    </div>
  </Fragment>
)}
