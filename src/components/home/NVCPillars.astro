---
const pillars = [
  {
    number: '01',
    label: 'Gözlem',
    description: 'Değerlendirme yapmadan gözlemlediğimizi somut biçimde ifade ederiz.',
    color: 'var(--color-plum-400)',
  },
  {
    number: '02',
    label: 'Duygu',
    description: 'Gözlemimizle ilişkili olarak ne hissettiğimizi fark ederiz.',
    color: 'var(--color-plum-500)',
  },
  {
    number: '03',
    label: 'İhtiyaç',
    description: 'Duygularımıza zemin olan ihtiyaçları, değerleri, arzuları ortaya koyarız.',
    color: 'var(--color-orchid-500)',
  },
  {
    number: '04',
    label: 'Rica',
    description: 'Hayatımızı zenginleştirecek eylemleri net biçimde dile getiririz.',
    color: 'var(--color-plum-700)',
  },
];
---

<section class="section-padding bg-[var(--color-surface)]">
  <div class="container-site">
    <!-- Section header -->
    <div class="mb-10 lg:mb-16 max-w-2xl">
      <p class="eyebrow mb-3" data-reveal>Şiddetsiz İletişim</p>
      <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-4" data-reveal data-reveal-delay="1">
        Dört adımda daha derin bir bağ
      </h2>
      <p class="text-[var(--color-ink-muted)] text-base lg:text-lg leading-relaxed" data-reveal data-reveal-delay="2">
        Marshall Rosenberg tarafından geliştirilen NVC modeli, empatiyi merkeze alır
        ve iletişimi dönüştürür.
      </p>
    </div>

    <!-- Mobile: vertical timeline / Desktop: horizontal stepper -->
    <div class="relative">
      <!-- Desktop connecting line -->
      <div
        class="hidden lg:block absolute top-8 left-0 right-0 h-px bg-gradient-to-r from-[var(--color-plum-200)] via-[var(--color-plum-400)] to-[var(--color-plum-700)]"
        aria-hidden="true"
      ></div>

      <div class="flex flex-col lg:flex-row gap-0 lg:gap-8">
        {pillars.map((pillar, i) => (
          <div class="relative flex lg:flex-col gap-5 lg:gap-0 flex-1" data-reveal data-reveal-delay={String(i + 1)}>
            <!-- Mobile connecting line -->
            {i < pillars.length - 1 && (
              <div
                class="lg:hidden absolute left-7 top-16 bottom-0 w-px bg-gradient-to-b from-[var(--color-plum-300)] to-[var(--color-plum-100)]"
                aria-hidden="true"
              ></div>
            )}

            <!-- Number node: ring + dot -->
            <div
              class="relative z-10 flex-shrink-0 w-14 h-14 lg:w-16 lg:h-16 rounded-full flex items-center justify-center lg:mb-6 font-display font-light text-lg bg-[var(--color-canvas)] border"
              style={`border-color: ${pillar.color}; color: ${pillar.color};`}
            >
              <span class="absolute inset-2 rounded-full opacity-[0.10]" style={`background-color: ${pillar.color};`} aria-hidden="true"></span>
              <span class="relative">{pillar.number}</span>
            </div>

            <!-- Content -->
            <div class="pb-8 lg:pb-0 lg:pr-4">
              <h3 class="font-display text-2xl lg:text-3xl font-light text-[var(--color-ink)] mb-2 lg:mb-3 -tracking-[0.02em]">
                {pillar.label}
              </h3>
              <p class="text-[var(--color-ink-muted)] text-sm lg:text-base leading-relaxed max-w-xs">
                {pillar.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-10 lg:mt-14">
      <a
        href="/nvc-nedir"
        class="inline-flex items-center gap-2 text-[var(--color-plum-700)] font-medium text-sm hover:text-[var(--color-plum-800)] transition-colors group"
      >
        Şiddetsiz İletişim hakkında daha fazla öğren
        <svg
          width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"
          class="transition-transform group-hover:translate-x-1"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
