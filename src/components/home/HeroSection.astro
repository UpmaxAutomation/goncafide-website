---
---

<section class="relative overflow-hidden bg-[var(--color-canvas)] pt-12 pb-16 lg:pt-20 lg:pb-24">
  <!-- Subtle background texture -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[var(--color-sage-50)] to-transparent opacity-60"></div>
  </div>

  <div class="container-site relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text column -->
      <div class="order-2 lg:order-1">
        <p class="eyebrow mb-4">CNVC Sertifikalı Eğitmen</p>

        <h1 class="font-display font-light leading-[1.05] -tracking-[0.04em] text-[var(--color-ink)] mb-6"
            style="font-size: clamp(2.75rem, 6vw, 5.5rem);">
          Şiddetsiz İletişim<br />
          <em class="font-light italic text-[var(--color-sage-700)]">Eğitmeni</em>
        </h1>

        <p class="text-[var(--color-ink-muted)] text-lg lg:text-xl leading-relaxed mb-8 max-w-lg">
          Kendimizle ve başkalarıyla daha derin bir bağ kurmak için NVC araçlarını öğrenin.
          1000+ saat eğitim deneyimiyle online gruplar ve bireysel seanslar.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
          <a
            href="/programlar"
            class="inline-flex items-center justify-center py-4 px-7 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] transition-all min-h-[52px] active:scale-[0.98]"
          >
            Programları Keşfet
          </a>
          <a
            href="/nvc-nedir"
            class="inline-flex items-center justify-center py-4 px-7 rounded-xl bg-transparent border border-[var(--color-ink)]/20 text-[var(--color-ink)] font-medium text-sm hover:bg-[var(--color-surface)] transition-all min-h-[52px]"
          >
            NVC Nedir?
          </a>
        </div>

        <!-- Social proof -->
        <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3">
          <div class="flex flex-col">
            <span class="font-display text-2xl font-light text-[var(--color-ink)]">1.000+</span>
            <span class="text-xs text-[var(--color-ink-muted)]">saat NVC eğitimi</span>
          </div>
          <div class="w-px h-8 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
          <div class="flex flex-col">
            <span class="font-display text-2xl font-light text-[var(--color-ink)]">900+</span>
            <span class="text-xs text-[var(--color-ink-muted)]">saat eğitim verdi</span>
          </div>
          <div class="w-px h-8 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
          <div class="flex flex-col">
            <span class="font-display text-2xl font-light text-[var(--color-ink)]">CNVC</span>
            <span class="text-xs text-[var(--color-ink-muted)]">Sertifikalı Eğitmen</span>
          </div>
        </div>
      </div>

      <!-- Visual column -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Decorative background shape -->
          <div
            class="absolute -inset-4 rounded-[2.5rem] bg-gradient-to-br from-[var(--color-sage-100)] to-[var(--color-sage-50)] -z-10"
            aria-hidden="true"
          ></div>

          <!-- Portrait -->
          <div
            class="w-64 h-80 sm:w-80 sm:h-96 lg:w-96 lg:h-[28rem] rounded-[2rem] overflow-hidden"
            style="box-shadow: var(--shadow-elevated);"
          >
            <img
              src="/images/gonca-fide.jpg"
              alt="Gonca Fide — CNVC Sertifikalı Şiddetsiz İletişim Eğitmeni"
              width="556"
              height="707"
              loading="eager"
              fetchpriority="high"
              class="w-full h-full object-cover object-top"
            />
          </div>

          <!-- Floating credential badge -->
          <div
            class="absolute -bottom-4 -left-4 lg:-left-8 bg-white rounded-2xl px-4 py-3"
            style="box-shadow: var(--shadow-card);"
          >
            <p class="text-xs font-semibold text-[var(--color-sage-700)] uppercase tracking-widest">CNVC</p>
            <p class="text-sm font-display font-light text-[var(--color-ink)]">Sertifikalı Eğitmen</p>
            <p class="text-xs text-[var(--color-ink-muted)]">2022'den beri</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
