---
// Hero — editorial, calm, motion-on-scroll. Slogan treated as a signature.
---

<section class="relative overflow-hidden bg-[var(--color-canvas)] pt-14 pb-16 lg:pt-24 lg:pb-28">
  <!-- Soft brand veil -->
  <div class="absolute inset-0 pointer-events-none brand-veil" aria-hidden="true"></div>

  <div class="container-site relative">
    <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-16 items-center">
      <!-- Text column -->
      <div class="order-2 lg:order-1">
        <p class="flex items-center gap-3 mb-6" data-reveal>
          <span class="h-px w-8 bg-[var(--color-terra-500)]" aria-hidden="true"></span>
          <span class="eyebrow !text-[var(--color-terra-500)] !mb-0">CNVC Sertifikalı Eğitmen</span>
        </p>

        <h1 class="font-display font-light leading-[1.02] -tracking-[0.04em] text-[var(--color-ink)] mb-5"
            style="font-size: clamp(2.9rem, 6.2vw, 5.75rem);" data-reveal data-reveal-delay="1">
          <em class="italic font-light text-[var(--color-sage-600)]">Şiddetsiz</em><br />
          İletişim Eğitmeni
        </h1>

        <!-- Slogan as signature -->
        <div class="flex items-center gap-4 mb-7" data-reveal data-reveal-delay="2">
          <span class="font-display text-2xl lg:text-[1.75rem] italic font-light text-[var(--color-terra-500)] leading-none">
            birbirine bağlar
          </span>
          <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-terra-400)]/50 to-transparent" aria-hidden="true"></span>
        </div>

        <p class="text-[var(--color-ink-muted)] text-lg lg:text-xl leading-relaxed mb-9 max-w-lg" data-reveal data-reveal-delay="3">
          Kendimizle ve başkalarıyla daha derin bir bağ kurmak için NVC araçlarını öğrenin.
          1000+ saat eğitim deneyimiyle online gruplar ve bireysel seanslar.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4" data-reveal data-reveal-delay="4">
          <a
            href="/programlar"
            class="group inline-flex items-center justify-center gap-2 py-4 px-7 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] transition-all min-h-[54px] active:scale-[0.98] shadow-[0_8px_24px_-8px_rgba(168,80,15,0.5)]"
          >
            Programları Keşfet
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a
            href="/nvc-nedir"
            class="inline-flex items-center justify-center py-4 px-7 rounded-xl bg-transparent border border-[var(--color-ink)]/15 text-[var(--color-ink)] font-medium text-sm hover:border-[var(--color-sage-400)] hover:bg-[var(--color-sage-50)] transition-all min-h-[54px]"
          >
            NVC Nedir?
          </a>
        </div>

        <!-- Credentials -->
        <div class="mt-11 flex flex-wrap items-center gap-x-7 gap-y-4" data-reveal data-reveal-delay="5">
          <div class="flex flex-col">
            <span class="font-display text-[1.65rem] font-light text-[var(--color-sage-700)] leading-none">1.000+</span>
            <span class="text-xs text-[var(--color-ink-muted)] mt-1.5">saat NVC eğitimi</span>
          </div>
          <div class="w-px h-9 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
          <div class="flex flex-col">
            <span class="font-display text-[1.65rem] font-light text-[var(--color-sage-700)] leading-none">900+</span>
            <span class="text-xs text-[var(--color-ink-muted)] mt-1.5">saat eğitim verdi</span>
          </div>
          <div class="w-px h-9 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
          <div class="flex flex-col">
            <span class="font-display text-[1.65rem] font-light text-[var(--color-sage-700)] leading-none">CNVC</span>
            <span class="text-xs text-[var(--color-ink-muted)] mt-1.5">Sertifikalı Eğitmen</span>
          </div>
        </div>
      </div>

      <!-- Visual column -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end" data-reveal data-reveal-delay="2">
        <div class="relative">
          <!-- Offset accent ring -->
          <div class="absolute -top-5 -right-5 w-full h-full rounded-[2.25rem] border border-[var(--color-terra-400)]/40" aria-hidden="true"></div>
          <!-- Organic halo -->
          <div class="absolute -inset-5 rounded-[2.75rem] bg-gradient-to-br from-[var(--color-sage-100)] to-[var(--color-sage-50)] -z-10" aria-hidden="true"></div>

          <div class="relative w-72 h-[22rem] sm:w-80 sm:h-96 lg:w-[26rem] lg:h-[31rem] rounded-[2.25rem] overflow-hidden" style="box-shadow: var(--shadow-elevated);">
            <img
              src="/images/gonca-fide.jpg"
              alt="Gonca Fide — CNVC Sertifikalı Şiddetsiz İletişim Eğitmeni"
              width="556" height="707" loading="eager" fetchpriority="high"
              class="w-full h-full object-cover object-top"
            />
            <!-- subtle bottom green wash for legibility / depth -->
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-[var(--color-sage-900)]/25 to-transparent" aria-hidden="true"></div>
          </div>

          <!-- Floating credential chip -->
          <div class="absolute -bottom-5 -left-4 lg:-left-9 bg-white rounded-2xl px-5 py-3.5 flex items-center gap-3" style="box-shadow: var(--shadow-card);">
            <span class="flex items-center justify-center w-9 h-9 rounded-full bg-[var(--color-sage-50)] text-[var(--color-sage-600)]" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4L4.1 7.7l5.4-.8L12 2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
            </span>
            <div class="leading-tight">
              <p class="text-[11px] font-semibold text-[var(--color-sage-700)] uppercase tracking-widest">CNVC</p>
              <p class="text-sm font-display font-light text-[var(--color-ink)]">2022’den beri</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
