---
// Pre-fill program field from URL param if provided
const prefilledProgram = Astro.url.searchParams.get('program') ?? '';

const programs = [
  { value: '', label: 'Program seçin (opsiyonel)' },
  { value: 'anda-kal-canda-kal', label: 'Anda Kal Canda Kal' },
  { value: 'anahtar-ayrimlar', label: 'Anahtar Ayrımlar' },
  { value: 'anlasmazlik-donusturme', label: 'Anlaşmazlık Dönüştürme' },
  { value: 'beceri-gelistirme', label: 'Beceri Geliştirme' },
  { value: 'mentorluk-programi', label: 'Mentörlük Programı' },
  { value: 'empatik-kocluk', label: 'Empatik Koçluk' },
  { value: 'diger', label: 'Diğer / Genel bilgi' },
];
---

<form
  name="iletisim"
  method="POST"
  action="/tesekkurler"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-5"
  aria-label="İletişim formu"
  novalidate
>
  <input type="hidden" name="form-name" value="iletisim" />
  <p class="hidden" aria-hidden="true">
    <label>Bunu doldurmayın: <input name="bot-field" /></label>
  </p>

  <!-- Name + Email: stacked on mobile, side by side on lg -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
        Adınız <span class="text-[var(--color-terra-500)]" aria-label="zorunlu">*</span>
      </label>
      <input
        id="name"
        type="text"
        name="name"
        required
        autocomplete="name"
        placeholder="Adınız Soyadınız"
        class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
        E-posta <span class="text-[var(--color-terra-500)]" aria-label="zorunlu">*</span>
      </label>
      <input
        id="email"
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="ornek@email.com"
        class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base"
      />
    </div>
  </div>

  <!-- Phone (optional) -->
  <div>
    <label for="phone" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
      Telefon <span class="text-[var(--color-ink-muted)] text-xs font-normal">(opsiyonel)</span>
    </label>
    <input
      id="phone"
      type="tel"
      name="phone"
      autocomplete="tel"
      placeholder="+90 5xx xxx xx xx"
      class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base"
    />
  </div>

  <!-- Program select -->
  <div>
    <label for="program" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
      İlgilendiğiniz program
    </label>
    <select
      id="program"
      name="program"
      class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base appearance-none cursor-pointer"
    >
      {programs.map((p) => (
        <option value={p.value} selected={p.value === prefilledProgram}>
          {p.label}
        </option>
      ))}
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
      Mesajınız <span class="text-[var(--color-terra-500)]" aria-label="zorunlu">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      placeholder="Merhaba, hakkında bilgi almak istiyorum..."
      class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base resize-y min-h-[140px]"
    ></textarea>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    class="w-full lg:w-auto flex items-center justify-center gap-2 py-4 px-8 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] active:scale-[0.98] transition-all min-h-[52px]"
  >
    Mesajı Gönder
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M2 8h12M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</form>
