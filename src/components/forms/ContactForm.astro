---
// Pre-fill program field from URL param if provided
const prefilledProgram = Astro.url.searchParams.get('program') ?? '';

const programs = [
  { value: '', label: 'Program seçin (opsiyonel)' },
  { value: 'anda-kal-canda-kal', label: 'Anda Kal Canda Kal' },
  { value: 'anahtar-ayrimlar', label: 'Anahtar Ayrımlar' },
  { value: 'anlasmazlik-donusturme', label: 'Anlaşmazlık Dönüştürme' },
  { value: 'beceri-gelistirme', label: 'Beceri Geliştirme' },
  { value: 'mentorluk-programi', label: 'Mentörlük Programı' },
  { value: 'empatik-kocluk', label: 'Empatik Koçluk' },
  { value: 'diger', label: 'Diğer / Genel bilgi' },
];
---

<form
  name="iletisim"
  method="POST"
  action="/api/contact"
  class="space-y-5"
  aria-label="İletişim formu"
  novalidate
>
  <input type="hidden" name="formType" value="iletisim" />
  <p class="hidden" aria-hidden="true">
    <label>Bunu doldurmayın: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </p>

  <!-- Name + Email: stacked on mobile, side by side on lg -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
        Adınız <span class="text-[var(--color-terra-500)]" aria-label="zorunlu">*</span>
      </label>
      <input
        id="name"
        type="text"
        name="name"
        required
        autocomplete="name"
        placeholder="Adınız Soyadınız"
        class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
        E-posta <span class="text-[var(--color-terra-500)]" aria-label="zorunlu">*</span>
      </label>
      <input
        id="email"
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="ornek@email.com"
        class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base"
      />
    </div>
  </div>

  <!-- Phone (optional) -->
  <div>
    <label for="phone" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
      Telefon <span class="text-[var(--color-ink-muted)] text-xs font-normal">(opsiyonel)</span>
    </label>
    <input
      id="phone"
      type="tel"
      name="phone"
      autocomplete="tel"
      placeholder="+90 5xx xxx xx xx"
      class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base"
    />
  </div>

  <!-- Program select -->
  <div>
    <label for="program" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
      İlgilendiğiniz program
    </label>
    <select
      id="program"
      name="program"
      class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base appearance-none cursor-pointer"
    >
      {programs.map((p) => (
        <option value={p.value} selected={p.value === prefilledProgram}>
          {p.label}
        </option>
      ))}
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-[var(--color-ink)] mb-2">
      Mesajınız <span class="text-[var(--color-terra-500)]" aria-label="zorunlu">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      placeholder="Merhaba, hakkında bilgi almak istiyorum..."
      class="w-full px-4 py-3.5 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:outline-none focus:ring-2 focus:ring-[var(--color-sage-300)] focus:border-[var(--color-sage-400)] transition-shadow text-base resize-y min-h-[140px]"
    ></textarea>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    data-submit
    class="group w-full lg:w-auto flex items-center justify-center gap-2 py-4 px-8 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] active:scale-[0.98] transition-all min-h-[52px] disabled:opacity-70 disabled:cursor-wait"
  >
    <span data-label>Mesajı Gönder</span>
    <svg data-arrow width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
      <path d="M2 8h12M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <svg data-spinner width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="hidden animate-spin">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" opacity="0.3"/>
      <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <p data-status role="status" aria-live="polite" class="hidden text-sm rounded-xl px-4 py-3"></p>
</form>

<script>
  function initContactForm() {
    const form = document.querySelector('form[name="iletisim"]');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = '1';
    const btn = form.querySelector('[data-submit]');
    const label = form.querySelector('[data-label]');
    const arrow = form.querySelector('[data-arrow]');
    const spinner = form.querySelector('[data-spinner]');
    const status = form.querySelector('[data-status]');

    function setStatus(msg, ok) {
      status.textContent = msg;
      status.className = 'text-sm rounded-xl px-4 py-3 ' + (ok
        ? 'bg-[var(--color-sage-50)] text-[var(--color-sage-800)] border border-[var(--color-sage-200)]'
        : 'bg-orange-50 text-[var(--color-terra-700)] border border-orange-200');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      btn.disabled = true;
      label.textContent = 'Gönderiliyor…';
      arrow.classList.add('hidden');
      spinner.classList.remove('hidden');
      status.className = 'hidden';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        setStatus('Teşekkürler! Mesajınız ulaştı. En kısa sürede geri döneceğim.', true);
      } catch (err) {
        setStatus('Bir sorun oluştu. Lütfen tekrar deneyin ya da WhatsApp’tan yazın: +90 533 716 79 40', false);
      } finally {
        btn.disabled = false;
        label.textContent = 'Mesajı Gönder';
        spinner.classList.add('hidden');
        arrow.classList.remove('hidden');
      }
    });
  }
  document.addEventListener('astro:page-load', initContactForm);
  if (document.readyState !== 'loading') initContactForm();
  else document.addEventListener('DOMContentLoaded', initContactForm);
</script>
