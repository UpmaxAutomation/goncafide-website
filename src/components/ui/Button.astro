---
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost' | 'outline' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  fullWidth?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: extraClass = '',
  fullWidth = false,
  ...rest
} = Astro.props;

const variantClasses = {
  primary: 'bg-[var(--color-terra-500)] text-white hover:bg-[var(--color-terra-600)] active:bg-[var(--color-terra-700)]',
  ghost: 'bg-transparent text-[var(--color-sage-700)] hover:bg-[var(--color-sage-50)] active:bg-[var(--color-sage-100)]',
  outline: 'bg-transparent border border-[var(--color-ink)] text-[var(--color-ink)] hover:bg-[var(--color-surface)]',
  dark: 'bg-[var(--color-sage-800)] text-white hover:bg-[var(--color-sage-700)] active:bg-[var(--color-sage-900)]',
};

const sizeClasses = {
  sm: 'py-2 px-4 text-xs min-h-[40px]',
  md: 'py-3 px-5 text-sm min-h-[48px]',
  lg: 'py-4 px-7 text-base min-h-[56px]',
};

const base = 'inline-flex items-center justify-center rounded-xl font-body font-semibold tracking-wide transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-sage-400)]';

const classes = [
  base,
  variantClasses[variant],
  sizeClasses[size],
  fullWidth ? 'w-full' : '',
  extraClass,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
