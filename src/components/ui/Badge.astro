---
interface Props {
  variant?: 'plum' | 'orchid' | 'neutral' | 'dark' | 'iris';
}

const { variant = 'plum' } = Astro.props;

const variantClasses = {
  plum: 'bg-[var(--color-plum-50)] text-[var(--color-plum-700)] border border-[var(--color-plum-200)]',
  orchid: 'bg-[var(--color-iris-50)] text-[var(--color-orchid-600)] border border-[var(--color-iris-200)]',
  neutral: 'bg-[var(--color-surface)] text-[var(--color-ink-muted)] border border-[var(--color-border)]',
  dark: 'bg-white/10 text-[var(--color-plum-100)] border border-white/10',
  iris: 'bg-[var(--color-iris-50)] text-[var(--color-iris-700)] border border-[var(--color-iris-200)]',
};
---

<span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-body font-medium ${variantClasses[variant]}`}>
  <slot />
</span>
