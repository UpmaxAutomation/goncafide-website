---
// Lightweight YouTube facade — shows the thumbnail + play button, and only
// loads the (cookie-less) iframe on click. Keeps the page fast and privacy-friendly.
interface Props {
  id: string;
  title: string;
  start?: number;
  class?: string;
}
const { id, title, start = 0, class: cls = '' } = Astro.props;
const thumb = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const params = `autoplay=1&rel=0&modestbranding=1${start ? `&start=${start}` : ''}`;
const src = `https://www.youtube-nocookie.com/embed/${id}?${params}`;
---

<div
  class={`yt-lite group relative w-full overflow-hidden rounded-2xl bg-[var(--color-sage-900)] ${cls}`}
  style="aspect-ratio: 16 / 9; box-shadow: var(--shadow-card);"
  data-yt-src={src}
>
  <button
    type="button"
    class="yt-lite-btn absolute inset-0 w-full h-full flex items-center justify-center cursor-pointer"
    aria-label={`Videoyu oynat: ${title}`}
  >
    <img
      src={thumb}
      alt={title}
      width="480"
      height="360"
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
    <span class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-black/20" aria-hidden="true"></span>
    <span
      class="relative flex items-center justify-center w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-white/95 text-[var(--color-terra-600)] transition-transform duration-300 group-hover:scale-110"
      style="box-shadow: 0 8px 28px -6px rgba(0,0,0,0.45);"
      aria-hidden="true"
    >
      <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
    </span>
  </button>
</div>

<script>
  function initYtLite() {
    document.querySelectorAll('.yt-lite:not([data-bound])').forEach((el) => {
      el.setAttribute('data-bound', '1');
      const btn = el.querySelector('.yt-lite-btn');
      btn?.addEventListener('click', () => {
        const src = el.getAttribute('data-yt-src');
        if (!src) return;
        const iframe = document.createElement('iframe');
        iframe.setAttribute('src', src);
        iframe.setAttribute('title', btn.getAttribute('aria-label') || 'YouTube');
        iframe.setAttribute(
          'allow',
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
        );
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('loading', 'lazy');
        iframe.className = 'absolute inset-0 w-full h-full';
        el.innerHTML = '';
        el.appendChild(iframe);
      });
    });
  }
  document.addEventListener('astro:page-load', initYtLite);
  if (document.readyState !== 'loading') initYtLite();
  else document.addEventListener('DOMContentLoaded', initYtLite);
</script>
