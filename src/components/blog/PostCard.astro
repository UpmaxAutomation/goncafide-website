---
import { formatDate } from '../../lib/formatDate';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  author?: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, pubDate, slug, author = 'Gonca Fide', tags = [], featured } = Astro.props;
---

<article
  class="group flex flex-col rounded-2xl bg-white overflow-hidden"
  style="box-shadow: var(--shadow-card);"
>
  <!-- Optional featured accent -->
  {featured && (
    <div class="h-1 bg-gradient-to-r from-[var(--color-terra-500)] to-[var(--color-terra-400)]"></div>
  )}

  <div class="flex flex-col flex-1 p-6 lg:p-7">
    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {tags.slice(0, 3).map((tag) => (
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-[var(--color-sage-50)] text-[var(--color-sage-700)] border border-[var(--color-sage-200)]">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Title -->
    <h3 class="font-display text-2xl font-light -tracking-[0.02em] text-[var(--color-ink)] mb-3 leading-snug group-hover:text-[var(--color-sage-800)] transition-colors flex-1">
      <a href={`/blog/${slug}`} class="hover:underline underline-offset-4 decoration-[var(--color-sage-300)]">
        {title}
      </a>
    </h3>

    <p class="text-[var(--color-ink-muted)] text-sm leading-relaxed mb-5">
      {description}
    </p>

    <!-- Meta -->
    <div class="flex items-center gap-3 text-xs text-[var(--color-ink-muted)]">
      <time datetime={pubDate.toISOString()}>
        {formatDate(pubDate)}
      </time>
      <span aria-hidden="true">·</span>
      <span>{author}</span>
    </div>
  </div>
</article>
