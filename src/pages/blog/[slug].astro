---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { readingTime } from '../../lib/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);

// Estimate reading time from raw body (Astro renders content on render)
const rt = readingTime(post.body ?? '');

const blogSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "url": `https://www.goncafide.com/blog/${post.id}`,
      "datePublished": post.data.pubDate.toISOString(),
      "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      "author": {
        "@type": "Person",
        "@id": "https://www.goncafide.com/#gonca"
      },
      "publisher": {
        "@type": "Person",
        "@id": "https://www.goncafide.com/#gonca"
      },
      "inLanguage": "tr"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.goncafide.com" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.goncafide.com/blog" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://www.goncafide.com/blog/${post.id}` }
      ]
    }
  ]
};
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  readingTime={rt}
  tags={post.data.tags}
>
  <JsonLd slot="jsonld" schema={blogSchema} />
  <Content />
</BlogPostLayout>
