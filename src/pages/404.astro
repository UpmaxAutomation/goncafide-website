---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Sayfa Bulunamadı"
  description="Aradığınız sayfa bulunamadı. Ana sayfaya dönebilir veya programları keşfedebilirsiniz."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center section-padding">
    <div class="container-site text-center max-w-xl mx-auto">
      <p class="font-display text-8xl lg:text-9xl font-light text-[var(--color-sage-200)] leading-none mb-6" aria-hidden="true">
        404
      </p>

      <h1 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-4">
        Sayfa Bulunamadı
      </h1>
      <p class="text-[var(--color-ink-muted)] text-lg leading-relaxed mb-10">
        Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl bg-[var(--color-sage-800)] text-white font-semibold text-sm hover:bg-[var(--color-sage-700)] transition-colors min-h-[48px]"
        >
          Ana Sayfaya Dön
        </a>
        <a
          href="/programlar"
          class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl border border-[var(--color-ink)]/20 text-[var(--color-ink)] font-medium text-sm hover:bg-[var(--color-surface)] transition-colors min-h-[48px]"
        >
          Programları Keşfet
        </a>
      </div>
    </div>
  </section>
</PageLayout>
