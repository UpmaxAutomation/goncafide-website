---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import JsonLd from '../components/seo/JsonLd.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "İletişim — Gonca Fide",
  "url": "https://www.goncafide.com/iletisim",
  "description": "Gonca Fide ile iletişime geçin. NVC programları, empati koçluğu ve bireysel seanslar hakkında bilgi alın.",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "info@goncafide.com",
    "telephone": "+90 533 716 79 40",
    "contactType": "customer service",
    "availableLanguage": "Turkish"
  }
};
---

<PageLayout
  title="İletişim"
  description="Gonca Fide ile iletişime geçin. NVC programları, empati koçluğu ve bireysel seanslar hakkında bilgi alabilirsiniz."
>
  <JsonLd slot="jsonld" schema={contactSchema} />

  <!-- Header -->
  <section class="bg-[var(--color-surface)] pt-12 pb-14 lg:pt-20 lg:pb-20 border-b border-[var(--color-border)]">
    <div class="container-site">
      <p class="eyebrow mb-4">İletişim</p>
      <h1 class="font-display text-4xl lg:text-5xl font-light -tracking-[0.04em] text-[var(--color-ink)] leading-[1.05] mb-4">
        İletişime Geçin
      </h1>
      <p class="text-[var(--color-ink-muted)] text-lg max-w-lg">
        Program kaydı, bireysel seans veya herhangi bir soru için mesaj gönderin.
        En kısa sürede geri döneceğim.
      </p>
    </div>
  </section>

  <!-- Form + contact info -->
  <section class="section-padding bg-[var(--color-canvas)]">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-2">
          <ContactForm />
        </div>

        <!-- Contact info sidebar -->
        <aside class="space-y-6">
          <div
            class="rounded-2xl bg-white p-6"
            style="box-shadow: var(--shadow-card);"
          >
            <p class="eyebrow text-[var(--color-sage-500)] mb-5">Diğer Kanallar</p>
            <div class="space-y-5">
              <div>
                <p class="text-xs font-medium text-[var(--color-ink-muted)] uppercase tracking-wider mb-1">WhatsApp & Telefon</p>
                <a
                  href="https://wa.me/905337167940"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-[var(--color-ink)] font-medium text-sm hover:text-[var(--color-sage-700)] transition-colors"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-[var(--color-sage-600)]"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 18.15c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 4.54 0 8.23 3.69 8.23 8.23 0 4.54-3.69 8.24-8.23 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
                  +90 533 716 79 40
                </a>
              </div>
              <div>
                <p class="text-xs font-medium text-[var(--color-ink-muted)] uppercase tracking-wider mb-1">E-posta</p>
                <a
                  href="mailto:info@goncafide.com"
                  class="text-[var(--color-ink)] font-medium text-sm hover:text-[var(--color-sage-700)] transition-colors"
                >
                  info@goncafide.com
                </a>
              </div>
              <div>
                <p class="text-xs font-medium text-[var(--color-ink-muted)] uppercase tracking-wider mb-1">Instagram</p>
                <a
                  href="https://instagram.com/goncolog"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--color-ink)] font-medium text-sm hover:text-[var(--color-sage-700)] transition-colors"
                >
                  @goncolog
                </a>
              </div>
              <div>
                <p class="text-xs font-medium text-[var(--color-ink-muted)] uppercase tracking-wider mb-1">Konum</p>
                <p class="text-[var(--color-ink)] text-sm">Ankara · Online</p>
              </div>
            </div>
          </div>

          <div
            class="rounded-2xl bg-[var(--color-sage-50)] p-6 border border-[var(--color-sage-200)]"
          >
            <p class="text-sm text-[var(--color-sage-800)] leading-relaxed">
              Mesajlara genellikle <strong>1-2 iş günü</strong> içinde yanıt veriyorum.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</PageLayout>
