---
import PageLayout from '../layouts/PageLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import YouTubeEmbed from '../components/ui/YouTubeEmbed.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": "Gonca Fide Hakkında",
  "url": "https://www.goncafide.com/hakkimda",
  "about": {
    "@type": "Person",
    "@id": "https://www.goncafide.com/#gonca",
    "name": "Gonca Fide"
  }
};

const credentials = [
  { year: '1999', label: 'ODTÜ Sosyoloji', detail: 'Orta Doğu Teknik Üniversitesi mezunu' },
  { year: '2000–2007', label: 'Kırsal Kalkınma Proje Yönetimi', detail: 'Ulusal ve uluslararası programlar' },
  { year: '2008–2012', label: 'Doğa Koruma Proje Yönetimi', detail: 'Yaban hayatı ve erozyon önleme projeleri' },
  { year: '2013–2016', label: 'BBOM Ankara Kooperatifi', detail: 'Genel Koordinatör ve Yönetim Kurulu Başkanı' },
  { year: '2017–2022', label: 'Sosyal Etki Uzmanlığı', detail: 'Enerji sektörü sosyal etki alanı' },
  { year: '2017–2022', label: 'Şiddetsiz İletişim Eğitmenliği', detail: 'Eğitim ve paylaşım süreci' },
  { year: "2022'den beri", label: 'CNVC Sertifikalı Eğitmen', detail: 'Center for Nonviolent Communication' },
  { year: '—', label: '1500+ saat Şiddetsiz İletişim eğitimi', detail: 'Alınan ve paylaşılan eğitim deneyimi' },
];

const background = [
  { area: 'Uluslararası Kalkınma', icon: 'globe' },
  { area: 'Doğa Koruma', icon: 'leaf' },
  { area: 'Enerji Sektörü Sosyal Etki', icon: 'spark' },
  { area: 'Alternatif Eğitim', icon: 'book' },
];

const bgIcons: Record<string, string> = {
  globe: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18" stroke="currentColor" stroke-width="1.5"/>',
  leaf: '<path d="M5 19c0-7 5-12 14-12 0 9-5 14-12 14-1.5 0-2-1-2-2zM5 19c2-4 5-6 9-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  spark: '<path d="M13 2L5 13h6l-2 9 8-11h-6l2-9z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  book: '<path d="M4 5.5A2 2 0 0 1 6 4h6v15H6a2 2 0 0 0-2 1.5V5.5zM20 5.5A2 2 0 0 0 18 4h-6v15h6a2 2 0 0 1 2 1.5V5.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
};
---

<PageLayout
  title="Hakkımda"
  description="Gonca Fide — ODTÜ Sosyoloji mezunu, CNVC Sertifikalı Şiddetsiz İletişim Eğitmeni. 1500+ saat Şiddetsiz İletişim eğitimi deneyimi."
>
  <JsonLd slot="jsonld" schema={schema} />

  <!-- Hero -->
  <section class="bg-[var(--color-surface)] pt-12 pb-16 lg:pt-20 lg:pb-24 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text -->
        <div>
          <p class="eyebrow mb-4">Hakkımda</p>
          <h1 class="font-display text-4xl lg:text-5xl font-medium -tracking-[0.02em] text-[var(--color-ink)] leading-[1.08] mb-6">
            Gonca Fide Kim?
          </h1>
          <p class="text-[var(--color-ink-muted)] text-lg leading-relaxed mb-6">
            ODTÜ Sosyoloji mezunuyum. Uluslararası ve ulusal programların kalkınma, doğa koruma, yaban hayatı ve erozyon önleme projelerinde görev aldım; enerji sektörünün sosyal etki alanında çalıştım. Sayısız Anadolu köyünü ziyaret ettiğimde, insanların farklılıktan çok benzerlikleri olduğunu ama bakış açılarını esnetmeyi daha önce deneyimlemedikleri için anlaşmazlık yaşadıklarını gözlemledim.
          </p>
          <p class="text-[var(--color-ink-muted)] text-lg leading-relaxed mb-8">
            2019'dan bu yana Şiddetsiz İletişim Türkiye Derneği üyesiyim. Liv Larsson, Miki Kashtan ve çok sayıda CNVC eğitmeninden 1500 saatin üzerinde Şiddetsiz İletişim eğitimi deneyimim oldu. Ağustos 2022'den beri CNVC (Uluslararası Şiddetsiz İletişim Merkezi) Sertifikalı Eğitmeniyim.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/programlar"
              class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] transition-colors min-h-[48px]"
            >
              Programları Keşfet
            </a>
            <a
              href="/iletisim"
              class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl border border-[var(--color-ink)]/20 text-[var(--color-ink)] font-medium text-sm hover:bg-[var(--color-surface)] transition-colors min-h-[48px]"
            >
              İletişime Geç
            </a>
          </div>
        </div>

        <!-- Portrait -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div
              class="absolute -inset-4 rounded-[2.5rem] bg-gradient-to-br from-[var(--color-sage-100)] to-[var(--color-sage-50)] -z-10"
              aria-hidden="true"
            ></div>
            <div
              class="w-64 h-80 sm:w-80 sm:h-96 rounded-[2rem] overflow-hidden"
              style="box-shadow: var(--shadow-elevated);"
            >
              <img
                src="/images/gonca-fide.jpg"
                alt="Gonca Fide — CNVC Sertifikalı Şiddetsiz İletişim Eğitmeni"
                width="556"
                height="707"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover object-top"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials timeline -->
  <section class="section-padding bg-[var(--color-canvas)]">
    <div class="container-site">
      <div class="max-w-2xl">
        <p class="eyebrow mb-4">Deneyim & Eğitim</p>
        <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-10">
          Niteliklerim
        </h2>

        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-[var(--color-sage-200)]" aria-hidden="true"></div>
          <div class="space-y-8 pl-12">
            {credentials.map((cred) => (
              <div class="relative">
                <div
                  class="absolute -left-8 top-1 w-4 h-4 rounded-full bg-[var(--color-sage-400)] border-2 border-[var(--color-canvas)]"
                  aria-hidden="true"
                ></div>
                <div>
                  <p class="text-xs font-medium text-[var(--color-sage-500)] mb-1 font-body uppercase tracking-wider">
                    {cred.year}
                  </p>
                  <h3 class="font-display text-xl font-light text-[var(--color-ink)] mb-1">
                    {cred.label}
                  </h3>
                  <p class="text-sm text-[var(--color-ink-muted)]">{cred.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Background areas -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="container-site">
      <p class="eyebrow mb-4">Geçmişim</p>
      <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-10">
        NVC öncesi: çeşitli alanlarda deneyim
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {background.map((item, i) => (
          <div
            class="card-rise p-5 lg:p-6 rounded-2xl bg-white text-center flex flex-col items-center"
            style="box-shadow: var(--shadow-card);"
            data-reveal data-reveal-delay={String((i % 4) + 1)}
          >
            <span class="w-11 h-11 mb-3 rounded-xl flex items-center justify-center bg-[var(--color-sage-50)] text-[var(--color-sage-600)]" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" set:html={bgIcons[item.icon]} />
            </span>
            <p class="font-body text-sm font-medium text-[var(--color-ink)]">{item.area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Story / mission -->
  <section class="section-padding bg-[var(--color-canvas)]">
    <div class="container-site">
      <div class="max-w-2xl">
        <p class="eyebrow mb-4">Yolculuğum</p>
        <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-6">
          Anlaşma zemini nasıl oluşur?
        </h2>
        <div class="space-y-5 text-[var(--color-ink-muted)] leading-relaxed max-w-[60ch]">
          <p>
            Anlaşma zemini oluşma ihtimalinin nasıl yaratılacağı her zaman kişisel merakım oldu.
            Kızım için okul ararken “Başka Bir Okul Mümkün” (BBOM) hareketiyle tanıştım; profesyonel
            hayatımın yanında gönüllü olarak BBOM Ankara Kooperatifi'nin kuruluş yıllarında Genel
            Koordinatörlük ve Yönetim Kurulu Başkanlığı yürüttüm, BBOM Derneği Yönetim Kurulu'nda
            etkin rol aldım.
          </p>
          <p>
            Eğitimde alternatif ve demokratik yaklaşımları öğrenirken Şiddetsiz İletişim ile tanıştım.
            Marshall Rosenberg'in “ihtiyaç odaklı yaklaşımı”yla iletişim alışkanlıklarımızı nasıl
            değiştirebileceğimizi deneyimledim. Cinsiyet, yaş, din, ırk ya da milliyet ayrımı olmadan,
            empatik doğamızdan yararlanarak iletişim kurmanın tekniğini paylaşıyorum.
          </p>
          <p>
            İhtiyaç odaklı ve empatiyle bezenmiş bu dilin “şiddetsizliği yaratma” konusunda çok güçlü
            olduğunu görüyorum; yayılması için elimden geleni yapmaya devam ediyorum. Eğitimlerim
            yaşatarak ve paylaşarak öğrenme alanları açmakla ilgili.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video & Podcast -->
  <section class="section-padding bg-[var(--color-surface-iris)]">
    <div class="container-site">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow mb-4">Video & Podcast</p>
        <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-4">
          Beni dinleyin, tanışalım
        </h2>
        <p class="text-[var(--color-ink-muted)] leading-relaxed">
          Şiddetsiz İletişim üzerine sohbetler ve podcast bölümleri. Birlikte çalışmadan önce
          sesimi ve yaklaşımımı buradan duyabilirsiniz.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
        <div data-reveal>
          <YouTubeEmbed id="N93XALPo0_k" start={73} title="Gonca Fide ile tanışın" />
          <p class="mt-3 font-display text-lg font-light text-[var(--color-ink)]">Tanışalım</p>
          <p class="text-sm text-[var(--color-ink-muted)]">Gonca Fide ve Şiddetsiz İletişim yolculuğu üzerine.</p>
        </div>
        <div data-reveal data-reveal-delay="1">
          <YouTubeEmbed id="LWQituchtPg" start={600} title="Podcast — Şiddetsiz İletişim sohbeti" />
          <p class="mt-3 font-display text-lg font-light text-[var(--color-ink)]">Podcast</p>
          <p class="text-sm text-[var(--color-ink-muted)]">Şiddetsiz İletişim üzerine bir podcast sohbeti.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact strip -->
  <section class="py-14 bg-[var(--color-sage-800)]">
    <div class="container-site text-center">
      <h2 class="font-display text-3xl lg:text-4xl font-light text-white mb-6 -tracking-[0.03em]">
        Sunduklarımı keşfetmeye hazır mısınız?
      </h2>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/programlar"
          class="inline-flex items-center justify-center py-4 px-8 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm hover:bg-[var(--color-terra-400)] transition-colors min-h-[52px]"
        >
          Sunduklarımı Keşfet
        </a>
        <a
          href="https://instagram.com/goncolog"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 py-4 px-8 rounded-xl border border-white/30 text-white font-medium text-sm hover:bg-white/10 transition-colors min-h-[52px]"
        >
          @goncolog
        </a>
      </div>
    </div>
  </section>
</PageLayout>
