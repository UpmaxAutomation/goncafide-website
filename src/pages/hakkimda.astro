---
import PageLayout from '../layouts/PageLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": "Gonca Fide Hakkında",
  "url": "https://www.goncafide.com/hakkimda",
  "about": {
    "@type": "Person",
    "@id": "https://www.goncafide.com/#gonca",
    "name": "Gonca Fide"
  }
};

const credentials = [
  { year: '2022', label: 'CNVC Sertifikalı Eğitmen', detail: 'Center for Nonviolent Communication' },
  { year: '2021+', label: '1000+ saat NVC eğitimi', detail: 'Liv Larsson, Miki Kashtan ve diğer CNVC eğitmenlerinden' },
  { year: '2019+', label: '900+ saat eğitim', detail: 'Online gruplar ve bireysel seanslar' },
  { year: '—', label: 'BBOM Ankara Kurucusu', detail: 'Alternatif eğitim kooperatifi' },
  { year: 'ODTÜ', label: 'Sosyoloji Mezunu', detail: 'Orta Doğu Teknik Üniversitesi' },
];

const background = [
  { area: 'Uluslararası Kalkınma', icon: '🌍' },
  { area: 'Doğa Koruma', icon: '🌿' },
  { area: 'Enerji Sektörü Sosyal Etki', icon: '⚡' },
  { area: 'Alternatif Eğitim', icon: '📚' },
];
---

<PageLayout
  title="Hakkımda"
  description="Gonca Fide — ODTÜ Sosyoloji mezunu, CNVC Sertifikalı Şiddetsiz İletişim Eğitmeni. 1000+ saat NVC eğitimi almış, 900+ saat eğitim vermiş."
>
  <JsonLd slot="jsonld" schema={schema} />

  <!-- Hero -->
  <section class="bg-[var(--color-surface)] pt-12 pb-16 lg:pt-20 lg:pb-24 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text -->
        <div>
          <p class="eyebrow mb-4">Hakkımda</p>
          <h1 class="font-display text-4xl lg:text-5xl xl:text-6xl font-light -tracking-[0.04em] text-[var(--color-ink)] leading-[1.05] mb-6">
            Gonca Fide Kim?
          </h1>
          <p class="text-[var(--color-ink-muted)] text-lg leading-relaxed mb-6">
            ODTÜ Sosyoloji mezunuyum. Uluslararası kalkınma, doğa koruma ve enerji sektöründe sosyal etki alanlarında çalıştıktan sonra, empati ve iletişim alanındaki derin merakım beni Şiddetsiz İletişim'e yöneltti.
          </p>
          <p class="text-[var(--color-ink-muted)] text-lg leading-relaxed mb-8">
            2019'dan bu yana NVC topluluğunun içindeyim. Liv Larsson, Miki Kashtan ve çok sayıda CNVC eğitmeninden 1000+ saat eğitim aldım. 2022'de CNVC Sertifikalı Eğitmen oldum ve bugüne kadar 900+ saat eğitim verdim.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/programlar"
              class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm tracking-wide hover:bg-[var(--color-terra-600)] transition-colors min-h-[48px]"
            >
              Programları Keşfet
            </a>
            <a
              href="/iletisim"
              class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl border border-[var(--color-ink)]/20 text-[var(--color-ink)] font-medium text-sm hover:bg-[var(--color-surface)] transition-colors min-h-[48px]"
            >
              İletişime Geç
            </a>
          </div>
        </div>

        <!-- Portrait placeholder -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div
              class="w-64 h-80 sm:w-80 sm:h-96 rounded-[2rem] overflow-hidden bg-gradient-to-br from-[var(--color-sage-200)] to-[var(--color-sage-100)] flex items-center justify-center"
              style="box-shadow: var(--shadow-elevated);"
            >
              <div class="text-center">
                <p class="font-display text-8xl font-light text-[var(--color-sage-500)] opacity-50">GF</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials timeline -->
  <section class="section-padding bg-[var(--color-canvas)]">
    <div class="container-site">
      <div class="max-w-2xl">
        <p class="eyebrow mb-4">Deneyim & Eğitim</p>
        <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-10">
          Niteliklerim
        </h2>

        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-[var(--color-sage-200)]" aria-hidden="true"></div>
          <div class="space-y-8 pl-12">
            {credentials.map((cred) => (
              <div class="relative">
                <div
                  class="absolute -left-8 top-1 w-4 h-4 rounded-full bg-[var(--color-sage-400)] border-2 border-[var(--color-canvas)]"
                  aria-hidden="true"
                ></div>
                <div>
                  <p class="text-xs font-medium text-[var(--color-sage-500)] mb-1 font-body uppercase tracking-wider">
                    {cred.year}
                  </p>
                  <h3 class="font-display text-xl font-light text-[var(--color-ink)] mb-1">
                    {cred.label}
                  </h3>
                  <p class="text-sm text-[var(--color-ink-muted)]">{cred.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Background areas -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="container-site">
      <p class="eyebrow mb-4">Geçmişim</p>
      <h2 class="font-display text-3xl lg:text-4xl font-light -tracking-[0.03em] text-[var(--color-ink)] mb-10">
        NVC öncesi: çeşitli alanlarda deneyim
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {background.map((item) => (
          <div
            class="p-5 lg:p-6 rounded-2xl bg-white text-center"
            style="box-shadow: var(--shadow-card);"
          >
            <div class="text-3xl mb-3" aria-hidden="true">{item.icon}</div>
            <p class="font-body text-sm font-medium text-[var(--color-ink)]">{item.area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact strip -->
  <section class="py-14 bg-[var(--color-sage-800)]">
    <div class="container-site text-center">
      <h2 class="font-display text-3xl lg:text-4xl font-light text-white mb-6 -tracking-[0.03em]">
        Hizmetleri keşfetmeye hazır mısınız?
      </h2>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/hizmetler"
          class="inline-flex items-center justify-center py-4 px-8 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm hover:bg-[var(--color-terra-400)] transition-colors min-h-[52px]"
        >
          Hizmetleri Keşfet
        </a>
        <a
          href="https://instagram.com/goncolog"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 py-4 px-8 rounded-xl border border-white/30 text-white font-medium text-sm hover:bg-white/10 transition-colors min-h-[52px]"
        >
          @goncolog
        </a>
      </div>
    </div>
  </section>
</PageLayout>
