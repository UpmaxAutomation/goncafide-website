---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

// Upcoming events only. Past-dated and draft entries are filtered out.
// The collection starts empty → honest "no scheduled dates yet" state.
const now = new Date();
const all = await getCollection('etkinlikler', ({ data }) => !data.draft);
const upcoming = all
  .filter((e) => new Date(e.data.startDate) >= new Date(now.toDateString()))
  .sort((a, b) => new Date(a.data.startDate).getTime() - new Date(b.data.startDate).getTime());

const fmt = (d: Date) =>
  new Date(d).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });

const eventsSchema = upcoming.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      'itemListElement': upcoming.map((e, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'item': {
          '@type': 'Event',
          'name': e.data.title,
          'startDate': new Date(e.data.startDate).toISOString().slice(0, 10),
          ...(e.data.endDate ? { 'endDate': new Date(e.data.endDate).toISOString().slice(0, 10) } : {}),
          'eventAttendanceMode':
            e.data.format === 'Online Grup'
              ? 'https://schema.org/OnlineEventAttendanceMode'
              : 'https://schema.org/OfflineEventAttendanceMode',
          'organizer': { '@type': 'Person', 'name': 'Gonca Fide' },
          ...(e.data.description ? { 'description': e.data.description } : {}),
        },
      })),
    }
  : null;
---

<PageLayout
  title="Etkinlikler"
  description="Gonca Fide ile yaklaşan Şiddetsiz İletişim atölyeleri ve seminerleri. Yeni dönem tarihleri ve kayıt bilgileri."
>
  {eventsSchema && (
    <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(eventsSchema)} />
  )}

  <!-- Header -->
  <section class="bg-[var(--color-surface)] pt-12 pb-14 lg:pt-20 lg:pb-20 border-b border-[var(--color-border)]">
    <div class="container-site">
      <p class="eyebrow mb-4">Etkinlikler</p>
      <h1 class="font-display text-4xl lg:text-5xl font-light -tracking-[0.04em] text-[var(--color-ink)] leading-[1.05] mb-4">
        Yaklaşan atölyeler
      </h1>
      <p class="text-[var(--color-ink-muted)] text-lg max-w-xl">
        Yeni dönem grup programları ve tek oturumluk seminerlerin tarihlerini burada paylaşıyorum.
      </p>
    </div>
  </section>

  <section class="section-padding bg-[var(--color-canvas)]">
    <div class="container-site">
      {upcoming.length > 0 ? (
        <div class="max-w-3xl space-y-4">
          {upcoming.map((e) => (
            <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 p-6 rounded-2xl bg-white" style="box-shadow: var(--shadow-card);">
              <div class="flex-shrink-0 sm:w-40">
                <p class="font-display text-lg text-[var(--color-sage-700)]">{fmt(e.data.startDate)}</p>
                {e.data.endDate && <p class="text-xs text-[var(--color-ink-muted)]">— {fmt(e.data.endDate)}</p>}
                <span class="inline-block mt-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-[var(--color-sage-50)] text-[var(--color-sage-700)] border border-[var(--color-sage-200)]">{e.data.format}</span>
              </div>
              <div class="flex-1">
                <h2 class="font-display text-xl font-light -tracking-[0.02em] text-[var(--color-ink)] leading-snug">{e.data.title}</h2>
                {e.data.description && <p class="text-[var(--color-ink-muted)] text-sm mt-1.5 leading-relaxed">{e.data.description}</p>}
              </div>
              <a
                href={e.data.enrollmentUrl ?? '/iletisim'}
                {...(e.data.enrollmentUrl ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                class="flex-shrink-0 inline-flex items-center justify-center py-3 px-5 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm hover:bg-[var(--color-terra-600)] transition-colors min-h-[44px]"
              >
                {e.data.enrollmentOpen ? 'Kayıt' : 'Bilgi al'}
              </a>
            </div>
          ))}
        </div>
      ) : (
        <div class="max-w-xl mx-auto text-center py-10">
          <div class="w-14 h-14 mx-auto mb-6 rounded-2xl bg-[var(--color-sage-50)] text-[var(--color-sage-500)] flex items-center justify-center" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M7 3v3M17 3v3M3.5 9h17M5 5h14a1.5 1.5 0 0 1 1.5 1.5V19A1.5 1.5 0 0 1 19 20.5H5A1.5 1.5 0 0 1 3.5 19V6.5A1.5 1.5 0 0 1 5 5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h2 class="font-display text-2xl lg:text-3xl font-light text-[var(--color-ink)] mb-3 -tracking-[0.02em]">
            Şu an planlanmış bir tarih yok
          </h2>
          <p class="text-[var(--color-ink-muted)] leading-relaxed mb-8">
            Yeni dönem atölyeleri açıldığında ilk siz haberdar olun. Bültene katılın
            ya da doğrudan yazın — size uygun bir grup oluştuğunda haber vereyim.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/iletisim" class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm hover:bg-[var(--color-terra-600)] transition-colors min-h-[48px]">
              İletişime Geç
            </a>
            <a href="/programlar" class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl border border-[var(--color-ink)]/20 text-[var(--color-ink)] font-medium text-sm hover:bg-[var(--color-surface)] transition-colors min-h-[48px]">
              Programları İncele
            </a>
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
