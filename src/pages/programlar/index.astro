---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ProgramCard from '../../components/programs/ProgramCard.astro';

const allPrograms = await getCollection('programlar', ({ data }) => !data.draft);
const programs = allPrograms.sort((a, b) => a.data.order - b.data.order);

const groupPrograms = programs.filter((p) => p.data.format === 'Online Grup');
const individualPrograms = programs.filter((p) => p.data.format === 'Bireysel (1:1)');

// Group the online-group programs by level (Gonca's taxonomy: Başlangıç → İleri)
const LEVEL_ORDER = ['Başlangıç', 'Orta', 'Orta-İleri', 'İleri', 'Tüm Seviyeler'];
const byLevel = LEVEL_ORDER
  .map((level) => ({ level, items: groupPrograms.filter((p) => p.data.level === level) }))
  .filter((g) => g.items.length > 0);

const seminerler = (await getCollection('seminerler', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const levelBlurb: Record<string, string> = {
  'Başlangıç': 'Şiddetsiz İletişim’e ilk adım — temel kavramlar ve dört adım.',
  'Orta': 'Giriş sonrası beceriyi pratikte derinleştiren programlar.',
  'Orta-İleri': 'Kavramları inceltip ileri seviyeye taşıyan derinleşme.',
  'İleri': 'Anlaşmazlık dönüştürme ve eğitmenliğe giden yol.',
  'Tüm Seviyeler': 'Her seviyeden katılımcıya açık çalışmalar.',
};
---

<PageLayout
  title="Sunduklarım"
  description="Gonca Fide’nin Şiddetsiz İletişim programları: başlangıçtan ileri seviyeye grup kursları, tematik seminerler ve bireysel seanslar. Online NVC eğitimleri."
>
  <!-- Header -->
  <section class="bg-[var(--color-surface)] pt-12 pb-14 lg:pt-20 lg:pb-20 border-b border-[var(--color-border)]">
    <div class="container-site">
      <p class="eyebrow mb-4">Sunduklarım</p>
      <h1 class="font-display text-4xl lg:text-5xl font-light -tracking-[0.04em] text-[var(--color-ink)] leading-[1.05] mb-4">
        NVC yolculuğunuzu<br />seçin
      </h1>
      <p class="text-[var(--color-ink-muted)] text-lg max-w-xl">
        Her seviye ve ihtiyaç için bir alan var: başlangıçtan ileri seviyeye grup programları,
        tek oturumluk tematik seminerler ve bire bir seanslar.
      </p>
    </div>
  </section>

  <!-- 3-level overview -->
  <section class="bg-[var(--color-canvas)] pt-10 lg:pt-14">
    <div class="container-site">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {['Başlangıç', 'Orta', 'İleri'].map((lvl, i) => (
          <div class="flex items-start gap-3 p-5 rounded-2xl bg-[var(--color-surface)]">
            <span class="font-display text-2xl font-light text-[var(--color-terra-500)] leading-none">{i + 1}</span>
            <div>
              <p class="font-body font-semibold text-sm text-[var(--color-ink)]">{lvl} Seviye</p>
              <p class="text-xs text-[var(--color-ink-muted)] mt-1 leading-relaxed">{levelBlurb[lvl]}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Group programs, grouped by level -->
  {byLevel.map((group) => (
    <section class="section-padding bg-[var(--color-canvas)] !pb-0 last:!pb-[var(--spacing-section)]">
      <div class="container-site">
        <div class="mb-8">
          <p class="eyebrow mb-3">{group.level} Seviye</p>
          <h2 class="font-display text-2xl lg:text-3xl font-light -tracking-[0.03em] text-[var(--color-ink)]">
            {levelBlurb[group.level]}
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
          {group.items.map((program) => (
            <ProgramCard
              title={program.data.title}
              description={program.data.description}
              level={program.data.level}
              format={program.data.format}
              totalHours={program.data.totalHours}
              sessionDuration={program.data.sessionDuration}
              slug={program.id}
              enrollmentOpen={program.data.enrollmentOpen}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Tematik Seminerler -->
  {seminerler.length > 0 && (
    <section class="section-padding bg-[var(--color-surface)]">
      <div class="container-site">
        <div class="mb-8">
          <p class="eyebrow mb-3">Tematik Seminerler</p>
          <h2 class="font-display text-2xl lg:text-3xl font-light -tracking-[0.03em] text-[var(--color-ink)]">
            Tek oturumluk atölyeler
          </h2>
          <p class="text-[var(--color-ink-muted)] mt-3 max-w-xl">
            Belirli bir temayı NVC merceğiyle ele alan, tek seanslık buluşmalar.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
          {seminerler.map((s) => (
            <div class="flex flex-col p-6 lg:p-7 rounded-2xl bg-white" style="box-shadow: var(--shadow-card);">
              <div class="flex items-center gap-2 mb-3 flex-wrap">
                <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-[var(--color-sage-50)] text-[var(--color-sage-700)] border border-[var(--color-sage-200)]">{s.data.level}</span>
                <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-[var(--color-surface)] text-[var(--color-ink-muted)] border border-[var(--color-border)]">{s.data.format}</span>
              </div>
              <h3 class="font-display text-xl font-light -tracking-[0.02em] text-[var(--color-ink)] mb-2.5 leading-snug">{s.data.title}</h3>
              <p class="text-[var(--color-ink-muted)] text-sm leading-relaxed flex-1">{s.data.description}</p>
              <a href="/iletisim" class="mt-5 inline-flex items-center gap-1.5 text-[var(--color-terra-500)] hover:text-[var(--color-terra-600)] text-sm font-medium transition-colors">
                Bilgi al
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Individual sessions -->
  {individualPrograms.length > 0 && (
    <section class="section-padding bg-[var(--color-canvas)]">
      <div class="container-site">
        <div class="mb-8">
          <p class="eyebrow mb-3">Bireysel Seanslar</p>
          <h2 class="font-display text-2xl lg:text-3xl font-light -tracking-[0.03em] text-[var(--color-ink)]">
            Sizinle bire bir
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 lg:gap-6 lg:max-w-2xl">
          {individualPrograms.map((program) => (
            <ProgramCard
              title={program.data.title}
              description={program.data.description}
              level={program.data.level}
              format={program.data.format}
              totalHours={program.data.totalHours}
              sessionDuration={program.data.sessionDuration}
              slug={program.id}
              enrollmentOpen={program.data.enrollmentOpen}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Corporate cross-link -->
  <section class="bg-[var(--color-surface)] py-12 border-t border-[var(--color-border)]">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5">
        <div>
          <h2 class="font-display text-xl lg:text-2xl font-light text-[var(--color-ink)] -tracking-[0.02em]">Kurumunuz için özel tasarım</h2>
          <p class="text-[var(--color-ink-muted)] text-sm mt-1 max-w-lg">Ekipler ve organizasyonlar için ihtiyaca göre tasarlanmış NVC eğitimleri.</p>
        </div>
        <a href="/kurumsal" class="inline-flex items-center justify-center py-3.5 px-6 rounded-xl border border-[var(--color-sage-300)] text-[var(--color-sage-700)] font-semibold text-sm hover:bg-[var(--color-sage-50)] transition-colors min-h-[48px] flex-shrink-0">
          Kurumsal Eğitimler
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[var(--color-sage-800)] py-16">
    <div class="container-site text-center">
      <h2 class="font-display text-3xl font-light text-white mb-4 -tracking-[0.03em]">
        Hangi program size uygun?
      </h2>
      <p class="text-[var(--color-cream)]/70 mb-8 max-w-md mx-auto">
        Bir programı seçmekte zorlanıyorsanız, birlikte konuşabiliriz.
      </p>
      <a
        href="/iletisim"
        class="inline-flex items-center justify-center py-4 px-8 rounded-xl bg-[var(--color-terra-500)] text-white font-semibold text-sm hover:bg-[var(--color-terra-600)] transition-colors min-h-[52px]"
      >
        İletişime Geç
      </a>
    </div>
  </section>
</PageLayout>
