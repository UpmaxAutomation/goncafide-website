# GoHighLevel webhook URL — paste the webhook endpoint from GHL > Triggers > Webhook
# When set, every contact/newsletter submission is POSTed as JSON to this URL.
GHL_CONTACT_WEBHOOK=

# Resend.com API key — create one at https://resend.com/api-keys
# When set, an email notification is sent to info@goncafide.com on each submission.
# The "from" domain (goncafide.com) must be verified in your Resend account first.
RESEND_API_KEY=
